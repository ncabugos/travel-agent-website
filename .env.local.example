# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Sanity ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys (use test key in dev)
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret from your webhook endpoint — REQUIRED in production.
# In local dev you can leave this unset and `stripe listen` will provide one.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── App ─────────────────────────────────────────────────────────────────────
# Used for Stripe checkout success/cancel URLs and Supabase email templates.
# Set to https://eliteadvisorhub.com in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
